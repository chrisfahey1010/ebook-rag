DATABASE_URL=postgresql+psycopg://ebook_rag:ebook_rag@localhost:5432/ebook_rag
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# Benchmark-backed chunking defaults.
CHUNK_TARGET_WORDS=420
CHUNK_MIN_WORDS=180
CHUNK_OVERLAP_WORDS=64
CHUNK_MAX_HEADING_WORDS=12

# Local-first provider defaults.
EMBEDDING_PROVIDER=hashing
RERANKER_PROVIDER=token_overlap
ANSWER_PROVIDER=extractive

# Ollama via the OpenAI-compatible `/v1` surface.
# EMBEDDING_PROVIDER=openai_compatible
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_API_KEY=not-needed
# EMBEDDING_MODEL=nomic-embed-text
#
# RERANKER_PROVIDER=openai_compatible
# RERANKER_BASE_URL=http://localhost:11434/v1
# RERANKER_API_KEY=not-needed
# RERANKER_MODEL=bge-reranker-v2-m3
#
# ANSWER_PROVIDER=openai_compatible
# ANSWER_BASE_URL=http://localhost:11434/v1
# ANSWER_API_KEY=not-needed
# ANSWER_MODEL=llama3.2
# ANSWER_TIMEOUT_SECONDS=60
# ANSWER_TEMPERATURE=0
# ANSWER_MAX_TOKENS=400

# llama.cpp server via its OpenAI-compatible `/v1` surface.
# EMBEDDING_PROVIDER=sentence_transformer
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
#
# RERANKER_PROVIDER=cross_encoder
# RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
#
# ANSWER_PROVIDER=openai_compatible
# ANSWER_BASE_URL=http://localhost:8080/v1
# ANSWER_API_KEY=not-needed
# ANSWER_MODEL=Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
# ANSWER_TIMEOUT_SECONDS=60
# ANSWER_TEMPERATURE=0
# ANSWER_MAX_TOKENS=400

# Example mixed mode: keep local retrieval, use hosted generation.
# ANSWER_PROVIDER=openai_compatible
# ANSWER_BASE_URL=https://api.openai.com/v1
# ANSWER_API_KEY=your-api-key
# ANSWER_MODEL=gpt-4o-mini
